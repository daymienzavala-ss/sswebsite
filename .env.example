# Contact form email delivery (Resend) — set these in Vercel → Project → Settings → Environment Variables
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. Defaults to: StangScales <noreply@stangscales.net>
# Requires the domain to be verified in Resend. Before verifying, you can test with:
#   CONTACT_FROM="StangScales <onboarding@resend.dev>"
CONTACT_FROM=

# Optional. Where inquiries are delivered. Defaults to daymien.zavala@stangscales.net
CONTACT_TO=
